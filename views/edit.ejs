<%- include('includes/_head', { title: 'Edit Character' }) %>
<%- include('includes/_nav', { subtitle: 'Edit Character' }) %>

<a class="button is-link mb-4" href="/personajes">Back to Characters</a>

<form action="/personajes/<%= personaje.id %>/edit" method="POST">
    <div class="field">
        <label for="nombre" class="label">Name</label>
        <div class="control">
            <input id="nombre" name="nombre" class="input" type="text" value="<%= personaje.nombre %>">
        </div>
    </div>
    <div class="field">
        <label for="descripcion" class="label">Description</label>
        <div class="control">
            <input id="descripcion" name="descripcion" class="input" type="text" value="<%= personaje.descripcion %>">
        </div>
    </div>
    <div class="field">
        <label for="tipo" class="label">Role</label>
        <div class="control">
            <div class="select">
                <select id="tipo" name="tipo">
                    <% tipos.forEach(t => { %>
                        <option value="<%= t.id %>" <%= t.id === personaje.tipo_id ? 'selected' : '' %>><%= t.tipo %></option>
                    <% }) %>
                </select>
            </div>
        </div>
    </div>
    <div class="field">
        <label for="imagen" class="label">Image URL</label>
        <div class="control">
            <input id="imagen" name="imagen" class="input" type="text" value="<%= personaje.imagen %>">
        </div>
    </div>
    <input class="button is-primary" type="submit" value="Save Changes">
</form>

<%- include('includes/_footer') %>
