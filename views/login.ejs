<%- include('includes/_head', { title: 'Log In' }) %>
<%- include('includes/_nav', { subtitle: 'to your Account' }) %>

<a class="button is-link mb-4" href="/personajes">Back to Characters</a>

<% if (lastVisit) { %>
    <p class="mb-4">Welcome back! Your last login was: <strong><%= lastVisit %></strong></p>
<% } %>

<% if (error) { %>
    <div class = "notification is-danger"><%= error %></div>
<% } %>

<form action="/users/login" method="POST">
    <div class="field">
        <label for="username" class="label">Name</label>
        <div class="control">
            <input id="username" name="username" class="input" type="text" placeholder="e.g oompalucca">
        </div>
    </div>
    <div class="">
        <label for="password" class="label">Description</label>
        <div class="control">
            <input id="password" name="password" class="input" type="password" placeholder="e.g. Password">
        </div>
    </div>

    <input class="button is-primary" type="submit" value="Log In">
</form>

<%- include('includes/_footer') %>